# Backend application port inside the container.
PORT=3001

# Prisma SQLite connection string for the backend container volume.
DATABASE_URL=file:/app/data/dev.db

# OpenAI API key for image analysis and seasonal tips generation.
OPENAI_API_KEY=

# OpenAI model name, e.g. gpt-4o or another supported vision-capable model.
OPENAI_MODEL=gpt-4o

# OpenAI sampling temperature, e.g. 0.2
OPENAI_TEMPERATURE=0.2

# OpenAI max token limit for completions, e.g. 1000
OPENAI_MAX_TOKENS=800

# Public frontend origin used by backend CORS.
FRONTEND_URL=https://zhao.aibr.cz

# Frontend API base URL baked into the production build.
VITE_API_URL=/api
